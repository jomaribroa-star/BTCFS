</section>

<!-- ENROLL -->
<section class="enroll" id="enroll">
  <div class="enroll-inner">
    <div>
      <div class="section-eyebrow">Admissions</div>
      <h2 class="section-title">Ready to Join the BTCFS Family?</h2>
      <p class="section-sub">Enrollment is open for the current school year. Follow these steps to get started.</p>
      <div class="enroll-steps">
        <div class="step">
          <div class="step-num">1</div>
          <div>
            <h4>Submit an Inquiry</h4>
            <p>Fill out the form or visit us at Grand Terrace Subd., Casili Road, Consolacion.</p>
          </div>
        </div>
