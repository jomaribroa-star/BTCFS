            <p>A DepEd-aligned K–12 curriculum with dedicated teachers committed to meaningful learning.</p>
          </div>
        </div>
        <div class="pillar">
          <div class="pillar-icon">🌱</div>
          <div>
            <h4>Character Formation</h4>
            <p>Values-based education that develops integrity, discipline, and compassion in every student.</p>
          </div>
        </div>
        <div class="pillar">
          <div class="pillar-icon">🤝</div>
          <div>
            <h4>Community Partnership</h4>
            <p>Active involvement with DepEd Cebu Province, local organizations, and parent communities.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- PROGRAMS -->
<section class="programs" id="programs">
  <div class="programs-inner">
    <div class="programs-header">
      <div class="section-eyebrow">Education Levels</div>
      <h2 class="section-title">Programs We Offer</h2>
      <p class="section-sub">From Kindergarten to Senior High School, our curriculum is designed to meet each child where they are and carry them forward.</p>
    </div>
    <div class="programs-grid">
      <div class="program-card">
        <div class="icon">🌟</div>
        <h3>Kindergarten</h3>
