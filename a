        <div class="stat-label">Holistic Formation</div>
      </div>
    </div>
  </div>
</section>

<!-- ABOUT -->
<section class="about" id="about">
  <div class="about-grid">
    <div class="about-visual">
      <div class="about-visual-icon">🏫</div>
      <h3>BTC Formation School, Inc.</h3>
      <p>Located at Grand Terrace Subdivision, Casili Road, Consolacion, Cebu — our school is a private institution dedicated to nurturing learners from Kindergarten through Senior High School.</p>
      <div class="gold-line"></div>
